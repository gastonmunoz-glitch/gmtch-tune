NODE_ENV=development
PORT=5000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=gmtch_tune_db
DB_USER=postgres
DB_PASSWORD=CAMBIAR_PASSWORD

JWT_SECRET=CAMBIAR_JWT_SECRET

# Bootstrap OWNER de un solo uso. Mantener deshabilitado cuando ya exista un OWNER.
# Username: 3-60 caracteres [A-Za-z0-9._-]. Password: 16-72 bytes y 3 categorias.
OWNER_BOOTSTRAP_ENABLED=false
OWNER_INITIAL_USERNAME=
OWNER_INITIAL_PASSWORD=

DB_ALTER=true
FRONTEND_URL=http://localhost:5173

CLOUDINARY_CLOUD_NAME=CAMBIAR_CLOUD_NAME
CLOUDINARY_API_KEY=CAMBIAR_API_KEY
CLOUDINARY_API_SECRET=CAMBIAR_API_SECRET

# Railway:
# NODE_ENV=production
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# DB_ALTER=true
# FRONTEND_URL=https://tu-frontend.up.railway.app
