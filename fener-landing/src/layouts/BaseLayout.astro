---
import "../styles/global.css";
import { brand, contact, seo } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = seo.defaultTitle,
  description = seo.defaultDescription,
  image = seo.image,
} = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, seo.siteUrl).toString();
const ogImageUrl = new URL(image, seo.siteUrl).toString();

const structuredData = {
  "@context": "https://schema.org",
  "@type": "FoodService",
  name: brand.name,
  url: seo.siteUrl,
  image: ogImageUrl,
  description,
  telephone: contact.phoneHref ? contact.phoneLabel : undefined,
  email: contact.email,
  address: {
    "@type": "PostalAddress",
    addressCountry: "CL",
  },
  areaServed: {
    "@type": "Country",
    name: "Chile",
  },
  servesCuisine: [
    "Servicios de alimentacion",
    "Alimentacion institucional",
    "Catering corporativo",
    "Banqueteria",
    "Cocteleria",
    "Cafeterias corporativas",
  ],
  knowsAbout: [
    "servicios de alimentacion para empresas",
    "alimentacion institucional",
    "catering corporativo",
    "alimentacion para colegios",
    "servicios de alimentacion en Chile",
  ],
};
---

<!doctype html>
<html lang="es-CL">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="servicios de alimentacion para empresas, alimentacion institucional, catering corporativo, banqueteria para empresas, cafeterias corporativas, alimentacion para colegios, servicios de alimentacion en Chile, catering y cocteleria, alimentacion diaria para empresas"
    />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#123C32" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_CL" />
    <meta property="og:site_name" content={brand.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>
