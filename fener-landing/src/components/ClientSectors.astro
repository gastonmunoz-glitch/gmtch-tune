---
import { clientPlaceholders, clientSectors } from "../data/site";
---

<section class="bg-white py-20 lg:py-24">
  <div class="section-shell">
    <div class="grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-end">
      <div>
        <span class="eyebrow">Clientes y rubros</span>
        <h2 class="mt-5 text-3xl font-black leading-tight text-fener-ink sm:text-4xl">
          Atencion a empresas, colegios, universidades, ministerios e instituciones.
        </h2>
      </div>
      <p class="text-lg leading-8 text-fener-slate">
        Aun no se publican nombres ni logos de clientes sin autorizacion. La web queda preparada con placeholders elegantes para incorporar material aprobado.
      </p>
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {clientSectors.map((sector) => (
        <article class="rounded-lg border border-stone-200 bg-fener-cream p-6">
          <h3 class="text-xl font-black text-fener-ink">{sector.title}</h3>
          <p class="mt-3 text-sm leading-6 text-fener-slate">{sector.description}</p>
        </article>
      ))}
    </div>

    <div class="mt-12 rounded-lg border border-stone-200 bg-white p-6 shadow-sm lg:p-8">
      <p class="text-sm font-black uppercase text-fener-gold">Clientes e instituciones atendidas</p>
      <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {clientPlaceholders.map((placeholder) => (
          <div class="grid min-h-24 place-items-center rounded-lg border border-dashed border-stone-300 bg-stone-50 px-4 text-center text-sm font-black text-fener-slate">
            {placeholder}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
