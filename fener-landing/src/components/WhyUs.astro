---
import { whyUs } from "../data/site";
---

<section id="por-que-fener" class="bg-fener-ink py-20 text-white lg:py-24">
  <div class="section-shell grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">
    <div>
      <span class="eyebrow border-white/10 bg-white/10 text-fener-gold">Por que elegir Fener</span>
      <h2 class="mt-5 text-3xl font-black leading-tight sm:text-4xl">
        Sabor familiar con control profesional.
      </h2>
      <p class="mt-5 text-lg leading-8 text-white/74">
        Un buen servicio alimentario no depende solo del menu. Tambien requiere orden, seguridad, puntualidad y respuesta rapida cuando el cliente lo necesita.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      {whyUs.map((item) => (
        <div class="flex gap-4 rounded-lg border border-white/10 bg-white/6 p-5">
          <span class="mt-1 grid size-8 shrink-0 place-items-center rounded-full bg-fener-gold text-sm font-black text-fener-ink">
            ✓
          </span>
          <p class="text-base font-bold leading-7 text-white">{item}</p>
        </div>
      ))}
    </div>
  </div>
</section>
