---
import { featuredServiceTitles, services } from "../data/site";

const featuredServices = services.filter((service) =>
  featuredServiceTitles.includes(service.title),
);
---

<section class="py-20 lg:py-24">
  <div class="section-shell">
    <div class="grid gap-8 lg:grid-cols-[0.82fr_1.18fr] lg:items-end">
      <div>
        <span class="eyebrow">Servicios principales</span>
        <h2 class="mt-5 text-3xl font-black leading-tight text-fener-ink sm:text-4xl">
          Alimentacion diaria y servicios especiales para operaciones exigentes.
        </h2>
      </div>
      <p class="text-lg leading-8 text-fener-slate">
        Fener trabaja con servicios recurrentes para empresas e instituciones, y con servicios especiales por solicitud para eventos, catering, cocteleria y banqueteria.
      </p>
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {featuredServices.map((service) => (
        <article class="rounded-lg border border-stone-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-soft">
          <p class="text-xs font-black uppercase text-fener-gold">{service.type}</p>
          <h3 class="mt-3 text-xl font-black leading-tight text-fener-ink">{service.title}</h3>
          <p class="mt-3 text-sm leading-6 text-fener-slate">{service.description}</p>
        </article>
      ))}
    </div>

    <div class="mt-10 flex flex-col gap-3 sm:flex-row">
      <a class="focus-ring inline-flex justify-center rounded-full bg-fener-green px-6 py-4 text-sm font-black text-white shadow-soft transition hover:bg-fener-ink" href="/servicios">
        Ver todos los servicios
      </a>
      <a class="focus-ring inline-flex justify-center rounded-full border border-fener-green/25 px-6 py-4 text-sm font-black text-fener-green transition hover:bg-fener-green hover:text-white" href="/contacto">
        Solicitar propuesta
      </a>
    </div>
  </div>
</section>
