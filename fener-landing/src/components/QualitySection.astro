---
import { quality } from "../data/site";
---

<section class="py-20 lg:py-24">
  <div class="section-shell">
    <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
      <div>
        <span class="eyebrow">{quality.eyebrow}</span>
        <h2 class="mt-5 text-3xl font-black leading-tight text-fener-ink sm:text-4xl">
          {quality.title}
        </h2>
      </div>
      <p class="text-lg leading-8 text-fener-slate">{quality.intro}</p>
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {quality.principles.map((item) => (
        <article class="rounded-lg border border-stone-200 bg-white p-6 shadow-sm">
          <div class="mb-5 h-1.5 w-16 rounded-full bg-fener-gold"></div>
          <h3 class="text-xl font-black text-fener-ink">{item.title}</h3>
          <p class="mt-3 text-sm leading-6 text-fener-slate">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
