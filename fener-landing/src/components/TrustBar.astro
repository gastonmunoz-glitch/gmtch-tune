---
import { metrics } from "../data/site";
---

<section class="border-y border-stone-200 bg-white">
  <div class="section-shell grid gap-0 divide-y divide-stone-200 py-2 sm:grid-cols-2 sm:divide-x sm:divide-y-0 lg:grid-cols-4">
    {metrics.map((metric) => (
      <article class="px-4 py-6 sm:px-6">
        <p class="text-lg font-black leading-tight text-fener-green">{metric.value}</p>
        <h2 class="mt-2 text-sm font-black uppercase text-fener-gold">{metric.label}</h2>
        <p class="mt-3 text-sm leading-6 text-fener-slate">{metric.description}</p>
      </article>
    ))}
  </div>
</section>
