---
import { processSteps } from "../data/site";
---

<section id="proceso" class="py-20 lg:py-24">
  <div class="section-shell">
    <div class="max-w-2xl">
      <span class="eyebrow">Proceso</span>
      <h2 class="mt-5 text-3xl font-black leading-tight text-fener-ink sm:text-4xl">
        De la solicitud a la entrega, sin improvisar.
      </h2>
      <p class="mt-4 text-lg leading-8 text-stone-700">
        Trabajamos con etapas simples para que sepas que se hara, cuando se hara y como se entregara.
      </p>
    </div>

    <div class="mt-10 grid gap-4 lg:grid-cols-4">
      {processSteps.map((step, index) => (
        <article class="relative rounded-lg border border-stone-200 bg-white p-6 shadow-sm">
          <span class="text-sm font-black text-fener-red">0{index + 1}</span>
          <h3 class="mt-4 text-xl font-black text-fener-ink">{step.title}</h3>
          <p class="mt-3 text-sm leading-6 text-stone-600">{step.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
