---
import { services } from "../data/site";

const iconPaths: Record<string, string> = {
  briefcase: "M4 7a2 2 0 0 1 2-2h3l1-2h4l1 2h3a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7Zm0 5h16M10 12v2h4v-2",
  education: "M3 8l9-4 9 4-9 4-9-4Zm4 3v5c2 2 8 2 10 0v-5M21 9v6",
  institution: "M3 21h18M5 21V9l7-5 7 5v12M9 21v-6h6v6M8 11h.01M12 11h.01M16 11h.01",
  coffee: "M5 8h11v6a5 5 0 0 1-5 5H10a5 5 0 0 1-5-5V8Zm11 2h2a3 3 0 0 1 0 6h-2M7 3v2M11 3v2M15 3v2",
  catering: "M4 19h16M6 19a6 6 0 0 1 12 0M12 5v2M8 8l1.5 1.5M16 8 14.5 9.5M4 13h16",
  toast: "M7 21h10M10 21v-7L5 4h5l2 5 2-5h5l-5 10v7",
  banquet: "M4 20h16M6 16h12M7 16a5 5 0 0 1 10 0M12 4v3M8 7l2 2M16 7l-2 2",
  calendar: "M7 3v4M17 3v4M4 9h16M6 5h12a2 2 0 0 1 2 2v11a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3V7a2 2 0 0 1 2-2Z",
  production: "M4 19h16M6 17V7h12v10M9 10h6M9 13h6M8 7V5h8v2",
  custom: "M12 2l1.8 5.4L19 9l-5.2 1.6L12 16l-1.8-5.4L5 9l5.2-1.6L12 2ZM19 15l.8 2.2L22 18l-2.2.8L19 21l-.8-2.2L16 18l2.2-.8L19 15Z",
  planning: "M5 4h14v16H5zM8 8h8M8 12h8M8 16h4",
};
---

<section class="py-20 lg:py-24">
  <div class="section-shell">
    <div class="max-w-3xl">
      <span class="eyebrow">Portafolio de servicios</span>
      <h2 class="mt-5 text-3xl font-black leading-tight text-fener-ink sm:text-4xl">
        Servicios alimentarios para empresas, educacion e instituciones.
      </h2>
      <p class="mt-4 text-lg leading-8 text-fener-slate">
        Cada servicio se estructura segun frecuencia, volumen, ubicacion, perfil de usuarios y condiciones operativas. Los servicios diarios son recurrentes; eventos, catering, cocteleria y banqueteria se gestionan por solicitud.
      </p>
    </div>

    <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {services.map((service) => (
        <article class="rounded-lg border border-stone-200 bg-white p-6 shadow-sm">
          <div class="flex items-start gap-4">
            <div class="grid size-12 shrink-0 place-items-center rounded-lg bg-fener-greenSoft text-fener-green">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d={iconPaths[service.icon]} stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <div>
              <p class="text-xs font-black uppercase text-fener-gold">{service.type}</p>
              <h3 class="mt-2 text-xl font-black leading-tight text-fener-ink">{service.title}</h3>
            </div>
          </div>
          <p class="mt-5 text-sm leading-6 text-fener-slate">{service.description}</p>
          <p class="mt-4 border-t border-stone-100 pt-4 text-sm leading-6 text-stone-600">{service.detail}</p>
        </article>
      ))}
    </div>
  </div>
</section>
