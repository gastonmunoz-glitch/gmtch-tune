---
import { homeHero } from "../data/site";

interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  image?: string;
  imageAlt?: string;
  compact?: boolean;
}

const props = Astro.props;
const eyebrow = props.eyebrow ?? homeHero.eyebrow;
const title = props.title ?? homeHero.title;
const description = props.description ?? homeHero.description;
const primaryLabel = props.primaryLabel ?? homeHero.primaryLabel;
const primaryHref = props.primaryHref ?? homeHero.primaryHref;
const secondaryLabel = props.secondaryLabel ?? homeHero.secondaryLabel;
const secondaryHref = props.secondaryHref ?? homeHero.secondaryHref;
const image = props.image ?? homeHero.image;
const imageAlt = props.imageAlt ?? homeHero.imageAlt;
const compact = props.compact ?? false;
---

<section class:list={["relative isolate overflow-hidden bg-fener-ink text-white", compact ? "pt-28" : "pt-32"]}>
  <img
    class="absolute inset-0 -z-20 h-full w-full object-cover"
    src={image}
    alt={imageAlt}
    loading="eager"
    fetchpriority="high"
  />
  <div class="absolute inset-0 -z-10 bg-gradient-to-r from-fener-ink via-fener-ink/86 to-fener-ink/38"></div>
  <div class="absolute inset-x-0 bottom-0 -z-10 h-28 bg-gradient-to-t from-fener-ink to-transparent"></div>

  <div class:list={["section-shell flex items-center", compact ? "min-h-[420px] py-16" : "min-h-[680px] py-20"]}>
    <div class="max-w-3xl">
      <span class="eyebrow border-white/15 bg-white/10 text-fener-gold">{eyebrow}</span>
      <h1 class="text-balance mt-6 text-4xl font-black leading-[1.02] sm:text-5xl lg:text-7xl">
        {title}
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-white/78 sm:text-xl">
        {description}
      </p>

      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        <a
          class="focus-ring inline-flex items-center justify-center rounded-full bg-fener-gold px-6 py-4 text-sm font-black text-fener-ink shadow-soft transition hover:bg-white"
          href={primaryHref}
        >
          {primaryLabel}
        </a>
        {secondaryHref && secondaryLabel && (
          <a
            class="focus-ring inline-flex items-center justify-center rounded-full border border-white/35 px-6 py-4 text-sm font-black text-white transition hover:bg-white hover:text-fener-ink"
            href={secondaryHref}
          >
            {secondaryLabel}
          </a>
        )}
      </div>
    </div>
  </div>
</section>
