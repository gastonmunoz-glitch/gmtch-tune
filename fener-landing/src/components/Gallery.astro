---
import { gallery } from "../data/site";
---

<section class="py-20 lg:py-24">
  <div class="section-shell">
    <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
      <div>
        <span class="eyebrow">Galeria corporativa</span>
        <h2 class="mt-5 text-3xl font-black leading-tight text-fener-ink sm:text-4xl">
          Espacios preparados para material real de Fener.
        </h2>
      </div>
      <p class="text-lg leading-8 text-fener-slate">
        Los bloques visuales quedan listos para reemplazar por fotografias reales de servicios diarios, cafeterias, catering, cocteleria, banqueteria, produccion y merchandising.
      </p>
    </div>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {gallery.map((item, index) => (
        <figure class="overflow-hidden rounded-lg border border-stone-200 bg-white shadow-sm">
          {item.image ? (
            <img
              class="h-72 w-full object-cover"
              src={item.image}
              alt={item.alt}
              loading={index === 0 ? "eager" : "lazy"}
            />
          ) : (
            <div class="flex h-72 flex-col justify-between bg-[linear-gradient(135deg,#123C32,#E7F0EB_54%,#F3E6CF)] p-6">
              <span class="w-fit rounded-full bg-white/90 px-3 py-1 text-xs font-black uppercase text-fener-green">
                Placeholder
              </span>
              <div>
                <p class="text-sm font-bold text-white/78">{item.category}</p>
                <p class="mt-2 text-2xl font-black leading-tight text-white">{item.title}</p>
              </div>
            </div>
          )}
          <figcaption class="p-5">
            <p class="text-xs font-black uppercase text-fener-gold">{item.category}</p>
            <h3 class="mt-2 text-xl font-black text-fener-ink">{item.title}</h3>
            <p class="mt-3 text-sm leading-6 text-fener-slate">{item.description}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
