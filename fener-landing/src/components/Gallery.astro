---
import { clientSectors, gallery } from "../data/site";
---

<section id="galeria" class="bg-white py-20 lg:py-24">
  <div class="section-shell">
    <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
      <div>
        <span class="eyebrow">Galeria</span>
        <h2 class="mt-5 text-3xl font-black leading-tight text-fener-ink sm:text-4xl">
          Preparada para mostrar tu produccion real.
        </h2>
      </div>
      <p class="text-lg leading-8 text-stone-700">
        La estructura queda lista para reemplazar estas imagenes por fotos propias de platos, eventos, equipos, produccion y entregas.
      </p>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {gallery.map((item, index) => (
        <figure class="group overflow-hidden rounded-lg border border-stone-200 bg-fener-cream shadow-sm">
          <img
            class="h-64 w-full object-cover transition duration-500 group-hover:scale-105"
            src={item.src}
            alt={item.alt}
            loading={index === 0 ? "eager" : "lazy"}
          />
          <figcaption class="p-4 text-sm font-black text-fener-ink">{item.title}</figcaption>
        </figure>
      ))}
    </div>

    <div class="mt-16 rounded-lg bg-fener-cream p-6 lg:p-8">
      <div class="grid gap-8 lg:grid-cols-[0.7fr_1.3fr] lg:items-center">
        <div>
          <span class="eyebrow bg-white">Clientes y rubros</span>
          <h3 class="mt-4 text-2xl font-black text-fener-ink">Rubros atendidos</h3>
        </div>
        <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {clientSectors.map((sector) => (
            <li class="rounded-lg border border-fener-red/10 bg-white px-4 py-3 text-sm font-bold text-stone-700">
              {sector}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
