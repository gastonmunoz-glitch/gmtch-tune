---
import { services } from "../data/site";

const icons: Record<string, string> = {
  building:
    "M4 21V7a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v14M9 21v-4h2v4M8 9h1M12 9h1M8 13h1M12 13h1M16 21h4V11a2 2 0 0 0-2-2h-2",
  calendar:
    "M7 3v4M17 3v4M4 9h16M6 5h12a2 2 0 0 1 2 2v11a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3V7a2 2 0 0 1 2-2Z",
  plate:
    "M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18ZM8 12h8M12 8v8",
  kitchen:
    "M5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16M9 7h6M9 11h6M9 15h2M15 15h.01",
  spark:
    "M12 2l1.9 5.6L20 10l-6.1 2.4L12 18l-1.9-5.6L4 10l6.1-2.4L12 2ZM19 15l.9 2.4L22 18l-2.1.6L19 21l-.9-2.4L16 18l2.1-.6L19 15Z",
};
---

<section id="servicios" class="py-20 lg:py-24">
  <div class="section-shell">
    <div class="max-w-2xl">
      <span class="eyebrow">Servicios</span>
      <h2 class="mt-5 text-3xl font-black leading-tight text-fener-ink sm:text-4xl">
        Soluciones alimentarias para operar con confianza.
      </h2>
      <p class="mt-4 text-lg leading-8 text-stone-700">
        Creamos propuestas claras para empresas, eventos y producciones que necesitan comida rica, buena presentacion y ejecucion responsable.
      </p>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
      {services.map((service) => (
        <article class="rounded-lg border border-stone-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-soft">
          <div class="grid size-12 place-items-center rounded-lg bg-fener-cream text-fener-red">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d={icons[service.icon]} stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <h3 class="mt-5 text-lg font-black leading-tight text-fener-ink">{service.title}</h3>
          <p class="mt-3 text-sm leading-6 text-stone-600">{service.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
