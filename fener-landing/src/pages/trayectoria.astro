---
import ContactCTA from "../components/ContactCTA.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import LegacySection from "../components/LegacySection.astro";
import NationalCoverage from "../components/NationalCoverage.astro";
import TrustBar from "../components/TrustBar.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { seo } from "../data/site";
---

<BaseLayout title={seo.pages.trayectoria.title} description={seo.pages.trayectoria.description}>
  <Header />
  <main>
    <Hero
      compact
      eyebrow="Trayectoria"
      title="Continuidad operativa de una trayectoria consolidada"
      description="Fener proyecta una experiencia relevante en servicios de alimentacion con una propuesta renovada para clientes institucionales, corporativos y educacionales."
      primaryLabel="Conocer servicios"
      primaryHref="/servicios"
      secondaryLabel="Contactar"
      secondaryHref="/contacto"
    />
    <TrustBar />
    <LegacySection />
    <NationalCoverage />
    <ContactCTA />
  </main>
  <Footer />
</BaseLayout>
